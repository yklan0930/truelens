// Prisma schema for TrueLens
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js standard models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // For credentials provider (bcrypt hash)
  isAdmin       Boolean   @default(false) // TrueLens staff / owner — unlimited detections
  plan          String    @default("free") // free | pro | business
  credits       Int       @default(0) // prepaid/monthly high-precision balance (Layer A, #131)
  creditsResetAt DateTime? // last monthly grant timestamp; null => grant on next use
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  usageRecords  UsageRecord[]
  detections    DetectionHistory[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── TrueLens custom models ───

/// Daily usage tracking per user (for free tier limits)
model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usage_records")
}

/// Detection history per user
model DetectionHistory {
  id             String   @id @default(cuid())
  userId         String
  imageName      String?
  aiProbability   Float
  isAI           Boolean
  confidence     Float
  processingTimeMs Int
  evidence       Json     // Array of evidence items
  locale         String   @default("en")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("detection_history")
}

/// Public share links: stores a detection result (+ small thumbnail) so it can
/// be viewed / downloaded online via /s/[id]. No auth required to create.
model SharedResult {
  id        String   @id @default(cuid())
  payload   String   @db.Text // JSON: { result: DetectionResult, thumbnail: string|null }
  locale    String   @default("en")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("shared_results")
}

/// Async video (AI / deepfake) detection jobs. The video bytes never pass
/// through Vercel functions — the browser uploads directly to blob storage and
/// the engine (Sightengine or mock) processes out-of-band, then calls our
/// webhook. The frontend polls /api/detect-video/status.
model VideoJob {
  id        String   @id @default(cuid())
  userId    String? // null = anonymous
  blobUrl   String?  @db.Text // public URL the engine fetches from
  fileName  String?
  fileSize  Int?
  status    String   @default("pending") // pending | processing | done | failed
  engine    String   @default("mock") // mock | sightengine
  result    Json? // VideoResult when done
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("video_jobs")
}

/// Daily video-detection usage per user (separate counter from images so the
/// heavier video quota can be tuned independently).
model VideoUsageRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("video_usage_records")
}

/// Global monthly Sightengine ops counter (Layer A, #131, spec §5.1).
/// Guards the vendor bill: when this month's ops hit MAX_SE_OPS_PER_MONTH
/// we force non-admins onto the zero-cost base model.
model MonthlyOps {
  id        String   @id @default(cuid())
  month     String   // YYYY-MM
  ops       Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month])
  @@map("monthly_ops")
}

/// Polar webhook idempotency (Layer B, overseas MoR). Each delivered Polar
/// event id is recorded once so retries never double-grant credits/plans.
model WebhookEvent {
  id        String   @id // Polar event id (order/subscription/checkout)
  type      String
  createdAt DateTime @default(now())

  @@map("webhook_events")
}
