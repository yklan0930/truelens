# Hugging Face API Token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Free tier rate limiting
DAILY_FREE_LIMIT=1

# --- Auth / Membership (requires DATABASE_URL + Vercel Postgres) ---
# Comma-separated emails that get admin privileges (unlimited detections + full report).
# Example: ADMIN_EMAILS=you@domain.com,boss@domain.com
ADMIN_EMAILS=

# Comma-separated emails pre-granted Pro (full report, higher daily limit).
# Example: PAID_EMAILS=vip@domain.com
PAID_EMAILS=
