# ─── Database (Prisma + Vercel Postgres) ───
# 在 Vercel 创建 Postgres 数据库后，复制其连接串粘贴到这里。
# 格式形如：postgresql://user:pass@host:5432/db?sslmode=require
# 配好后运行：bash scripts/db-push.sh  （建表 + 加 isAdmin/plan 字段）
DATABASE_URL=

# Hugging Face API Token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Free tier rate limiting
DAILY_FREE_LIMIT=1

# --- Auth / Membership (requires DATABASE_URL + Vercel Postgres) ---
# Comma-separated emails that get admin privileges (unlimited detections + full report).
# Example: ADMIN_EMAILS=you@domain.com,boss@domain.com
ADMIN_EMAILS=

# Comma-separated emails pre-granted Pro (full report, higher daily limit).
# Example: PAID_EMAILS=vip@domain.com
PAID_EMAILS=

# ─── Video (AI / deepfake) detection ───
# PRIMARY engine: Sightengine AI Video Detection (https://sightengine.com)
# 不配置时系统自动进入「演示模式」(mock)，整条异步流程仍可本地演示。
# 配置后切换为真实检测；视频文件由浏览器直传 Vercel Blob，永不经过 Vercel 函数。
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Vercel Blob（浏览器直传视频用，绕开 4.5MB 限制）。
# 在 Vercel 控制台 Storage 创建 Blob store 后复制 READ_WRITE_TOKEN。
# 未配置时演示模式可用；真实 Sightengine 路径需要它来生成可公开访问的视频 URL。
BLOB_READ_WRITE_TOKEN=

# 微信/Stripe 等支付接入（Phase 3）所需的商户密钥，留空即可先跑通检测。
# STRIPE_SECRET_KEY=

