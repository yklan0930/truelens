# ─── Database (Prisma + Vercel Postgres) ───
# 在 Vercel 创建 Postgres 数据库后，复制其连接串粘贴到这里。
# 格式形如：postgresql://user:pass@host:5432/db?sslmode=require
# 配好后运行：bash scripts/db-push.sh  （建表 + 加 isAdmin/plan 字段）
DATABASE_URL=

# Hugging Face API Token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Free tier rate limiting
DAILY_FREE_LIMIT=1

# --- Auth / Membership (requires DATABASE_URL + Vercel Postgres) ---
# Comma-separated emails that get admin privileges (unlimited detections + full report).
# Example: ADMIN_EMAILS=you@domain.com,boss@domain.com
ADMIN_EMAILS=

# Comma-separated emails pre-granted Pro (full report, higher daily limit).
# Example: PAID_EMAILS=vip@domain.com
PAID_EMAILS=

# ─── Sightengine AI Detection (image + video, SAME account) ───
# https://sightengine.com  — 图片与视频共用一个账户 / 同一个 genai 模型。
# 这套凭据同时驱动：
#   • 视频检测（PRIMARY 引擎，异步回调流程）
#   • 图片检测（v3.6 起作为 PRIMARY 引擎；未配置时退回免费 Ateeqq 模型 + 真实安全策略）
# 配置后图片检测立刻生效，无需额外订阅——只需填好下面两个变量即可。
# 不配置时：视频进入演示模式；图片退回 Ateeqq（对真人误判率高，仅作兜底）。
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Vercel Blob（浏览器直传视频用，绕开 4.5MB 限制）。
# 在 Vercel 控制台 Storage 创建 Blob store 后复制 READ_WRITE_TOKEN。
# 未配置时演示模式可用；真实 Sightengine 路径需要它来生成可公开访问的视频 URL。
BLOB_READ_WRITE_TOKEN=

# Layer A (#131): Global monthly Sightengine ops budget gate (spec §5.1).
# When this month's high-precision ops hit this cap, non-admins are forced
# onto the zero-cost base model so the vendor bill can never run away.
# Default 10000 = Starter tier. Set higher on Pro tier.
MAX_SE_OPS_PER_MONTH=10000

# 微信/支付宝 商户密钥（Phase 3 真实收银台用，Layer B）。
# 当前 Layer A 用模拟收银台(/api/checkout/mock)即可跑通"付费→到账credits"闭环，无需真实密钥。
# WECHAT_MCH_ID=
# WECHAT_APIV3_KEY=
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY=

